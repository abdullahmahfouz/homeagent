# Copy this file to .env.local and fill in real values.

# Free Mapbox public token: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# Backend URL. Leave unset in dev (defaults to http://localhost:8000).
# In production, set to your deployed backend URL, e.g. https://homeagent-api.onrender.com
VITE_API_URL=
